# ════════════════════════════════════════════════════════════
# Production — VM Proxmox / Docker, derrière Tailscale
# Copier en .env sur la VM puis compléter les valeurs marquées « À DÉFINIR ».
# ════════════════════════════════════════════════════════════

APP_NAME="Vivre Pleinement"
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# URL d'accès via Tailscale (nom MagicDNS de la VM ou IP tailnet).
# Exemple : http://ma-vm.ton-tailnet.ts.net:8080
APP_URL=http://CHANGER-EN-NOM-TAILSCALE:8080

# IP sur laquelle exposer le port (interface Tailscale de la VM).
# Laisser 127.0.0.1 si un reverse-proxy local s'en charge.
BIND_IP=127.0.0.1

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

# ─── Base de données (conteneur mariadb) ───
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=vivre_pleinement
DB_USERNAME=vivre
DB_PASSWORD=À_DÉFINIR_MOT_DE_PASSE_FORT

# ─── Cache / sessions / queue : tout en base, pas de Redis nécessaire ───
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Fichiers / médias ───
FILESYSTEM_DISK=local

# ─── Mail : driver log pour la démo privée (aucun envoi réel) ───
MAIL_MAILER=log
MAIL_FROM_ADDRESS="contact@vivre-pleinement.fr"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_CONTACT_TO="contact@vivre-pleinement.fr"

# ─── Services tiers désactivés pour la démo (laisser vide) ───
CASHIER_KEY=
CASHIER_SECRET=
STRIPE_KEY=
STRIPE_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

LOG_CHANNEL=stack
LOG_LEVEL=warning
